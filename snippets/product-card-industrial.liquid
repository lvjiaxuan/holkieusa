{%- if product != blank -%}

{%- liquid
  assign featured_media = product.featured_media
  assign product_url = product.url

  unless lazy_load == false
    assign loading = 'lazy'
    assign lazyimage = 'lazy-image'
  else
    assign loading = 'eager'
    assign lazyimage = null
  endunless
-%}

<div class="hb-product-card">

  <!-- IMAGE -->
  <a class="hb-product-card__image media media--square" href="{{ product_url }}">
    {%- if featured_media != blank -%}
      {{
        featured_media
        | image_url: width: 900
        | image_tag:
          loading: loading,
          widths: '360,540,720,900',
          class: 'hb-product-card__img',
          is: lazyimage
      }}
    {%- endif -%}
  </a>

  <!-- CONTENT -->
  <div class="hb-product-card__content">

    <!-- TITLE -->
    <h3 class="hb-product-card__title">
      <a href="{{ product_url }}">
        {{ product.title | escape }}
      </a>
    </h3>

    <!-- PRICE + BUTTON -->
    <div class="hb-product-card__purchase">

      <div class="hb-product-card__price">
        {%- if product.compare_at_price > product.price -%}
          <span class="hb-price hb-price--sale">
            {{ product.price | money }}
          </span>

          <span class="hb-price hb-price--compare">
            {{ product.compare_at_price | money }}
          </span>
        {%- else -%}
          <span class="hb-price">
            {{ product.price | money }}
          </span>
        {%- endif -%}
      </div>

      <a href="{{ product_url }}"
         class="hb-product-card__button">

        <span class="hidden md:block">
          Shop Now
        </span>

        <span class="md:hidden">
          {%- render 'icon', icon: 'cart', size: 'sm' -%}
        </span>

      </a>

    </div>

    <!-- SPECS -->
    {%- if product.metafields.custom.product_icons.value != blank -%}

      <div class="hb-product-card__specs">

        {%- assign specs = product.metafields.custom.product_icons.value -%}

        {%- for spec in specs limit: 4 -%}

          <div class="hb-spec">

            <div class="hb-spec__title">
              {{ spec.title }}
            </div>

            {%- if spec.description != blank -%}
              <div class="hb-spec__desc">
                {{ spec.description }}
              </div>
            {%- endif -%}

          </div>

        {%- endfor -%}

      </div>

    {%- endif -%}

  </div>

</div>

{%- endif -%}

{% assign rounded_card = '0.375rem' %}
{% if settings.rounded_input == 'round' %}
  {% assign rounded_input = '3.75rem' %}
{% elsif settings.rounded_input == 'square' %}
  {% assign rounded_input = '0rem' %}
{% endif %}

<style>
  :root {
    --card-radius: {{ rounded_card }};
    --input-radius: {{ rounded_input }};
  }

.hb-product-card{
  display:flex;
  flex-direction:column;
  height:100%;
  border:1px solid rgba(0,0,0,.08);
  border-radius:var(--card-radius);
  overflow:hidden;
  background:#fff;
  transition:all .2s ease;
}

.hb-product-card:hover{
  transform:translateY(-2px);
}

.hb-product-card__image{
  background:#fff;
  aspect-ratio:1/1;
}

.hb-product-card__img{
  width:100%;
  height:100%;
  object-fit:contain;
}

.hb-product-card__content{
  display:flex;
  flex-direction:column;
  gap:14px;
  padding:18px;
  flex-grow:1;
}

.hb-product-card__title{
  font-size:16px;
  font-weight:600;
  line-height:1.45;
  margin:0;

  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}

.hb-product-card__title a{
  color:inherit;
  text-decoration:none;
}

.hb-product-card__purchase{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
}

.hb-product-card__price{
  display:flex;
  flex-direction:column;
  line-height:1.2;
}

.hb-price{
  font-size:22px;
  font-weight:700;
  color: rgb(var(--color-price));
}

.hb-price--sale{
  color:#dc2626;
}

.hb-price--compare{
  font-size:13px;
  text-decoration:line-through;
  opacity:.55;
}

.hb-product-card__button{
  display:flex;
  align-items:center;
  justify-content:center;

  min-width:120px;
  height:44px;

  padding:0 18px;

  border-radius:12px;

  background:#f97316;
  color:#fff;

  text-decoration:none;

  font-size:14px;
  font-weight:600;
}

.hb-product-card__specs{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  padding-top:4px;
}

.hb-spec{
  background:#fff;
  border-radius:10px;
  padding:10px;
}

.hb-spec__title{
  font-size:13px;
  font-weight:600;
  line-height:1.35;
}

.hb-spec__desc{
  font-size:13px;
  opacity:.6;
  margin-bottom:4px;
}

@media screen and (max-width:768px){

  .hb-product-card__content{
    padding:14px;
    gap:12px;
  }

  .hb-product-card__title{
    font-size:14px;
  }

  .hb-price{
    font-size:18px;
  }

  .hb-product-card__button{
    min-width:44px;
    width:44px;
    padding:0;
  }

}

</style>

        {
          "type": "url",
          "id": "button_link_2",
          "label": "t:sections.footer.blocks.brand_information.settings.button_link_2.label"
        },
        {
          "type": "text",
          "id": "button_label_3",
          "label": "t:sections.footer.blocks.brand_information.settings.button_label_3.label"

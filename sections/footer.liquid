<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }

  /* Mobile accordion layout */
  @media (max-width: 767px) {
    .footer__menu-grid {
      display: flex;
      flex-direction: column;
    }

    .footer__menu-grid > details {
      border-bottom: 1px solid rgba(var(--color-text), 0.2);
    }

    .footer__menu-grid > details:last-child {
      border-bottom: none;
    }

    .footer__menu-grid > details .details__summary {
      padding-block: 1rem;
    }

    .footer__menu-grid > details .details__content {
      padding-block-end: 1rem;
    }

    .footer__menu-grid > details .details__content::after {
      padding-block-end: 0;
    }

    .footer__mobile-social {
      display: flex;
      gap: 1rem;
      padding-top: 1rem;
    }
  }

  /* Desktop layout - accordion appears as normal columns */
  @media (min-width: 768px) {
    .footer__menu-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      justify-content: space-around;
      flex: 1;
    }

    .footer__menu-grid > details {
      border-bottom: none !important;
    }

    .footer__menu-grid > details .details__summary {
      display: none !important;
    }

    .footer__menu-grid > details .details__content {
      padding-block-end: 0;
    }

    .footer__menu-grid > details .details__content::after {
      padding-block-end: 0;
    }

    .footer__mobile-social {
      display: none !important;
    }
  }
</style>

{%- liquid
  assign enable_footer_info = false
  if section.settings.enable_newsletter or section.settings.show_social or shop.features.follow_on_shop? and section.settings.enable_follow_on_shop
    assign enable_footer_info = true
  endif

  assign has_contact_block = false
  for block in section.blocks
    if block.type == 'contact_info'
      assign has_contact_block = true
      break
    endif
  endfor
-%}

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded{% endif %}"{% if section.settings.enable_parallax %} is="footer-parallax"{% endif %}>
  <div class="footer page-width{% if section.settings.full_width %} page-width--full{% endif %} relative" role="region" aria-label="Footer">
    <div class="flex flex-col gap-6 md:flex-row md:justify-center">
      {%- liquid
        assign logo_block = section.blocks | where: "type", "logo_social" | first
        if logo_block
          render 'footer-logo', block: logo_block
        endif
      -%}

      {% comment %} {# Menu grid (accordion on mobile, columns on desktop) #} {% endcomment %}
      <div class="footer__menu-grid w-full md:w-auto">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'link_list' -%}
              {%- render 'footer-menu', block: block -%}
            {%- when 'text' -%}
              {%- render 'footer-text', block: block -%}
            {%- when 'brand_information' -%}
              {%- render 'footer-contact', block: block -%}
            {%- when 'contact_info' -%}
              {%- render 'footer-contact-info', block: block -%}
          {%- endcase -%}
        {%- endfor -%}

        {% comment %} {# Social icons in mobile (when from logo block) #} {% endcomment %}
        {%- if section.settings.show_social and logo_block -%}
          <div class="footer__mobile-social">
            {%- render 'social-icons', size: 'md', gap: '4' -%}
          </div>
        {%- endif -%}
      </div>

      {% comment %} {# Desktop social icons (when placed in logo block) #} {% endcomment %}
      {%- if section.settings.show_social and logo_block -%}
        <div class="footer__socials hidden md:flex gap-4">
          {%- render 'social-icons', size: 'md', gap: '4' -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  {% comment %} {# Bottom newsletter bar #} {% endcomment %}
  {%- if section.settings.enable_newsletter or section.settings.show_social or shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
    <div class="footer__bar{% if section.settings.full_width %} page-width--full{% endif %}">
      <div class="footer__bar-inner page-width{% if section.settings.full_width %} page-width--full{% endif %} flex flex-col md:flex-row items-center gap-4 md:gap-8">
        {%- if section.settings.enable_newsletter -%}
          <div class="footer__bar-newsletter flex flex-col gap-4 flex-1 w-full">
            <p class="footer__bar-heading text-lg font-bold uppercase tracking-[0.2em]">{{ section.settings.newsletter_heading | escape }}</p>
            <div class="w-full">
              {%- render 'newsletter-form', section_id: section.id, context: 'footer-bar' -%}
            </div>
            {%- if section.settings.newsletter_text != blank -%}
              <div class="footer__bar-text text-sm opacity-80">{{ section.settings.newsletter_text }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.show_social and logo_block == nil -%}
          <div class="footer__bar-socials flex gap-4">
            {%- render 'social-icons', size: 'md', gap: '4' -%}
          </div>
        {%- endif -%}

        {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
          <div class="follow-on-shop shrink-0">
            {{- shop | login_button: action: 'follow' -}}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.enable_parallax -%}
    <parallax-overlay class="footer-overlay hidden md:block z-20 absolute left-0 top-0 w-full pointer-events-none" data-target="height" data-start="100%" data-stop="0%"></parallax-overlay>
  {%- endif -%}
</div>

{% schema %}
{

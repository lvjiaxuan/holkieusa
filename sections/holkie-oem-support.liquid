<style>
  .holkie-oem-section {
    width: 100%;
    background: linear-gradient(180deg,#2A0F0F 0%,#1A0B0B 100%);
    padding: 72px 0;
    position: relative;
    overflow: hidden;
  }

  .holkie-oem-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, rgba(254,215,0,0.10), transparent 30%),
      radial-gradient(circle at bottom left, rgba(255,255,255,0.04), transparent 40%);
    pointer-events: none;
  }

  .holkie-oem-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: minmax(0,1.05fr) minmax(0,0.95fr);
    gap: 44px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  /* LEFT */
  .holkie-oem-kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(254,215,0,0.12);
    border: 1px solid rgba(254,215,0,0.24);
    color: #F97316;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-bottom: 18px;
  }

  .holkie-oem-title {
    font-size: 42px;
    line-height: 1.02;
    font-weight: 800;
    color: #fff;
    margin: 0 0 18px;
  }

  .holkie-oem-title span {
    color: #FED700;
  }

  .holkie-oem-desc {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255,255,255,.82);
    margin-bottom: 28px;
    max-width: 580px;
  }

  .holkie-oem-buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .holkie-oem-btn-primary {
    background: #FED700;
    color: #111;
    padding: 14px 24px;
    border-radius: 10px;
    font-weight: 700;
    text-decoration: none;
  }

  .holkie-oem-btn-secondary {
    background: rgba(255,255,255,.06);
    color: #fff;
    padding: 14px 24px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,.14);
    text-decoration: none;
  }

  /* RIGHT GRID */
  .holkie-oem-right {
    display: grid;
    grid-template-columns: repeat(2,1fr);
    gap: 16px;
  }

  /* CARD */
  .holkie-oem-card {
    position: relative;
    overflow: hidden;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 18px;
    padding: 22px;
    transition: all .25s ease;
  }

  .holkie-oem-card:hover {
    transform: translateY(-2px);
    background: rgba(255,255,255,.08);
  }

  /* 🔥 关键：PNG背景轮廓 */
  .holkie-oem-bg-shape {
    position: absolute;       
    right: 0px;
    bottom: 0px;
    width: 120px;
    opacity: 0.10;
    pointer-events: none;
    z-index: 1;
    transform: rotate(-12deg);
    transition: all .4s ease;
  }

  .holkie-oem-card:hover .holkie-oem-bg-shape {
    transform: rotate(-12deg) scale(1.08);
    opacity: 0.16;
  }
  .holkie-oem-bg-shape svg {
  width: 100%;
  height: auto;
  fill: none;
  stroke: rgba(255,255,255,0.3);
  }
  .holkie-oem-card h3,
  .holkie-oem-card p {
    position: relative;
    z-index: 2;
  }

  .holkie-oem-card h3 {
    margin: 0 0 8px;
    font-size: 16px;
    font-weight: 700;
    color: #fff;
  }

  .holkie-oem-card p {
    margin: 0;
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255,255,255,.72);
  }

  @media (max-width: 980px) {
    .holkie-oem-inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }

  @media (max-width: 640px) {
    .holkie-oem-section {
      padding: 42px 0;
    }

    .holkie-oem-inner {
      padding: 0 20px;
    }

    .holkie-oem-right {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .holkie-oem-title {
      font-size: 28px;
    }
  }
</style>

<section class="holkie-oem-section">

  <div class="holkie-oem-inner">

    <div class="holkie-oem-left">

      <div class="holkie-oem-kicker">
        {{ section.settings.kicker }}
      </div>

      <h2 class="holkie-oem-title">
        {{ section.settings.heading }}
      </h2>

      <div class="holkie-oem-desc">
        {{ section.settings.description }}
      </div>

      <div class="holkie-oem-buttons">
        <a href="{{ section.settings.button_1_link }}" class="holkie-oem-btn-primary">
          {{ section.settings.button_1_text }}
        </a>

        <a href="{{ section.settings.button_2_link }}" class="holkie-oem-btn-secondary">
          {{ section.settings.button_2_text }}
        </a>
      </div>

    </div>

    <div class="holkie-oem-right">

      {% for block in section.blocks %}
        <article class="holkie-oem-card">
          <div class="holkie-oem-bg-shape">
          {{ block.settings.bg_svg }}
          </div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>

        </article>
      {% endfor %}

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Holkie OEM",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "OEM & BULK SUPPORT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Need Bulk Pricing or OEM Support?"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Holkie supports bulk orders, OEM projects, distributors, workshops, and industrial buyers worldwide."
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Primary Button",
      "default": "Request Quote"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Secondary Button",
      "default": "Talk to Holkie"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Secondary Button Link"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Support Card",
      "settings": [
        {
          "type": "textarea",
          "id": "bg_svg",
          "label": "Background SVG (paste code here)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Engineering Support"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Support for caster selection and OEM solutions."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Holkie OEM",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}
    "custom_liquid_7E7Epp": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "liquid": "<style>\n.holkie-why {\n  width: 100%;\n  background: #f8f9fb;\n  padding: 70px 20px;\n}\n\n.holkie-why-inner {\n  max-width: 1280px;\n  margin: 0 auto;\n}\n\n.holkie-why-head {\n  text-align: center;\n  margin-bottom: 42px;\n}\n\n.holkie-why-head h2 {\n  font-size: 36px;\n  line-height: 1.2;\n  font-weight: 700;\n  color: #1F2933;\n  margin: 0 0 12px;\n}\n\n.holkie-why-head p {\n  font-size: 16px;\n  color: #1F2933;\n  margin: 0;\n}\n\n.holkie-why-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 18px;\n}\n\n.holkie-why-card {\n  background: #fff;\n  border: 1px solid #e5e7eb;\n  border-radius: 14px;\n  padding: 28px;\n  transition: all .25s ease;\n}\n\n.holkie-why-card h3 {\n  font-size: 20px;\n  line-height: 1.3;\n  font-weight: 600;\n  color: #1F2933;\n  margin: 0 0 10px;\n}\n\n.holkie-why-card p {\n  font-size: 15px;\n  line-height: 1.7;\n  color: #666;\n  margin: 0;\n}\n\n@media screen and (max-width: 990px) {\n  .holkie-why {\n    padding: 56px 16px;\n  }\n\n  .holkie-why-head {\n    margin-bottom: 28px;\n  }\n\n  .holkie-why-head h2 {\n    font-size: 28px;\n  }\n\n  .holkie-why-grid {\n    grid-template-columns: repeat(2, 1fr);\n    gap: 14px;\n  }\n\n  .holkie-why-card {\n    padding: 22px;\n  }\n}\n\n@media screen and (max-width: 640px) {\n  .holkie-why {\n    padding: 46px 14px;\n  }\n\n  .holkie-why-head h2 {\n    font-size: 24px;\n  }\n\n  .holkie-why-head p {\n    font-size: 14px;\n    line-height: 1.6;\n  }\n\n  .holkie-why-grid {\n    grid-template-columns: repeat(2, 1fr);\ngap: 8px;\n  }\n\n  .holkie-why-card {\n    padding: 10px;\n    border-radius: 12px;\n  }\n\n  .holkie-why-card h3 {\n    font-size: 16px;\n    line-height: 1.35;\n  }\n\n  .holkie-why-card p {\n    font-size: 13px;\n    line-height: 1.55;\n  }\n}\n</style>\n\n<section class=\"holkie-why\">\n  <div class=\"holkie-why-inner\">\n\n    <div class=\"holkie-why-head\">\n      <h2>Why Choose Holkie</h2>\n      <p>\n        Built for industrial, commercial, retail, and OEM mobility solutions.\n      </p>\n    </div>\n\n    <div class=\"holkie-why-grid\">\n\n      <div class=\"holkie-why-card\">\n        <h3>US / CA / EU / UK Warehouses</h3>\n        <p>\n          Fast fulfillment for retail orders, distributors, and nationwide bulk shipments.\n        </p>\n      </div>\n\n      <div class=\"holkie-why-card\">\n        <h3>OEM & Custom Solutions</h3>\n        <p>\n          Custom wheels, brakes, stem sizes, packaging, and logo support available.\n        </p>\n      </div>\n\n      <div class=\"holkie-why-card\">\n        <h3>Bulk Order Support</h3>\n        <p>\n          MOQ-friendly pricing for factories, workshops, industrial projects, and resellers.\n        </p>\n      </div>\n\n      <div class=\"holkie-why-card\">\n        <h3>Certified Quality Standards</h3>\n        <p>\n          TÜV-tested materials and industrial-grade manufacturing standards for reliable performance.\n        </p>\n      </div>\n\n      <div class=\"holkie-why-card\">\n        <h3>Trusted by Global Buyers</h3>\n        <p>\n          Supporting distributors, OEM buyers, workshops, and online sellers worldwide.\n        </p>\n      </div>\n\n      <div class=\"holkie-why-card\">\n        <h3>Secure Checkout & Business Payments</h3>\n        <p>\n          Safe payments via cards, PayPal, and trusted purchasing workflows for business orders.\n        </p>\n      </div>\n\n    </div>\n  </div>\n</section>",
        "color_text": "",
        "color_background": "",
        "gradient_background": "",
        "color_button_text": "",
        "color_button_background": "",
        "color_button_gradient": "",
        "padding_top": 0,
        "padding_bottom": 0,
        "divider": false,
        "narrow": false,
        "full_width": false,
        "rounded": false
      }
    },
